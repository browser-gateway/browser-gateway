#!/usr/bin/env sh
# Pre-commit gate. ALL of these MUST pass locally before any commit.
# No CI for these — the cost of catching issues post-commit (revert, fix-up,
# force-push if shared) is too high. Catch them before they exist.
#
# Skipping is possible with --no-verify but should be reserved for emergency
# WIP commits to a feature branch. Never skip for commits headed to main.

set -e

cd "$(git rev-parse --show-toplevel)"

echo "▸ catalog:check  (helper inventory is current)"
npm run --silent catalog:check

echo "▸ lint           (tsc --noEmit)"
npm run --silent lint

echo "▸ lint:eslint    (sonarjs duplicate-function rules + unused vars)"
npm run --silent lint:eslint

echo "▸ lint:dup       (jscpd token-level duplication)"
npm run --silent lint:dup

echo "▸ lint:dead      (knip dead exports/deps)"
npm run --silent lint:dead

echo "▸ api:check      (public API surface lockfile)"
npm run --silent api:check

echo "▸ test:run       (full vitest suite, 289+ tests)"
npm run --silent test:run

echo "✓ all pre-commit gates passed"

{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/core/index.ts",
    "src/server/profile/index.ts",
    "tests/**/*.test.ts"
  ],
  "project": [
    "src/**/*.ts",
    "tests/**/*.ts"
  ],
  "ignoreBinaries": ["ffmpeg"],
  "ignoreDependencies": [
    "pino-pretty"
  ],
  "ignoreExportsUsedInFile": true,
  "tags": ["-public"],
  "rules": {
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "duplicates": "error",
    "files": "error",
    "dependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error"
  }
}
